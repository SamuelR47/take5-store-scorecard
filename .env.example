# Copy to .env for local testing. NEVER commit real values.
# In GitHub, set these as repo Secrets (not in code): Settings -> Secrets and variables -> Actions

AUTOPOLL_USER=your_autopoll_username
AUTOPOLL_PASS=your_autopoll_password

# Comma-separated store numbers. Pilot = 1512,1515. In GitHub set as a repo Variable named STORES.
STORES=1512,1515

# Supabase (optional until the DB is set up; leave blank to only write local files)
SUPABASE_URL=
SUPABASE_KEY=

# Where raw/parsed files are written locally
OUTPUT_DIR=Hourly Data Pull

# Set to 1 to bypass the open-hours check when testing
FORCE_RUN=0
